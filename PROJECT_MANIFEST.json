{
  "project": "DrawForge",
  "manifest_version": "1.0",
  "status": "experimental",
  "default_backend": "visio",
  "entrypoints": {
    "human": "GET_STARTED.md",
    "agent": "AGENT_START_HERE.md",
    "development": "DEVELOPMENT.md",
    "mode_policy": "MODE_POLICY.md",
    "detailed_agent_guide": "AGENT_GUIDE.md",
    "setup": "Setup/README.md"
  },
  "docs": {
    "index": "docs/README.md",
    "architecture": [
      "docs/architecture/README.md",
      "docs/architecture/LAYER_CONTRACTS.md",
      "docs/architecture/ARTIFACT_CONTRACTS.md",
      "docs/architecture/PLAN_TO_OPERATION_LOOP.md",
      "docs/architecture/FEEDBACK_PROMOTION_LOOP.md"
    ],
    "human": [
      "docs/human/README.md",
      "docs/human/PREVIEW_REVIEW_CHECKLIST.md",
      "docs/human/setup/AGENT_COLD_START_SMOKE_TEST.md",
      "docs/human/setup/WINDOWS_BRIDGE_DEPLOY.md",
      "docs/human/setup/SMOKE_TEST_FROM_WSL.md"
    ],
    "development": [
      "docs/dev/README.md",
      "docs/dev/PROJECT_STRUCTURE.md",
      "docs/dev/DEVELOPMENT_PLAN_STAGE1.md",
      "docs/dev/proposals/README.md"
    ]
  },
  "modes": {
    "operation": {
      "intent": "run or review a job without changing shared repo behavior by default",
      "recommended_write_scope": "job_only",
      "writable_paths": [
        "InputReference/**",
        "Setup/draw-job.local.json",
        "Setup/jobs/**",
        "OutputPreview/**",
        "OutputEditable/**"
      ],
      "frozen_by_default": [
        "agent/skills/plannerskills/**",
        "agent/skills/drawskills/**",
        "agent/skills/visioskills/**",
        "agent/skills/learningskills/**",
        "docs/**",
        "Setup/*.py",
        "Setup/*.schema.json",
        "Setup/draw-job.template.json"
      ]
    },
    "development": {
      "intent": "allow repo-level improvements when the blocker is structural",
      "recommended_write_scope": "repo_and_job",
      "writable_paths": [
        "InputReference/**",
        "Setup/**",
        "agent/skills/plannerskills/**",
        "agent/skills/drawskills/**",
        "agent/skills/visioskills/**",
        "agent/skills/learningskills/**",
        "docs/**",
        "OutputPreview/**",
        "OutputEditable/**"
      ]
    }
  },
  "agent_requirements": {
    "required_capabilities": [
      "read_local_files",
      "write_local_files",
      "run_shell_commands",
      "inspect_preview_images",
      "call_local_http_bridge"
    ],
    "optional_capabilities": [
      "git",
      "json_validation",
      "python_syntax_check"
    ]
  },
  "skills": {
    "planning": "agent/skills/plannerskills/",
    "drawing": "agent/skills/drawskills/",
    "execution": "agent/skills/visioskills/",
    "learning": "agent/skills/learningskills/"
  },
  "cold_start_protocol": {
    "read_order": [
      "PROJECT_MANIFEST.json",
      "MODE_POLICY.md",
      "AGENT_START_HERE.md",
      "AGENT_GUIDE.md",
      "Setup/README.md"
    ],
    "first_action": "run preflight before major drawing work",
    "blocker_routing": {
      "planning_or_priority": "agent/skills/plannerskills/",
      "layout_or_spacing": "agent/skills/drawskills/",
      "visio_operation_or_control": "agent/skills/visioskills/",
      "reusable_memory_or_lesson_promotion": "agent/skills/learningskills/"
    }
  },
  "improvement_loop": {
    "round_memory": "Setup/jobs/<job>/reviews/round-*.json",
    "proposal_hypotheses": "docs/dev/proposals/*.md",
    "validated_lessons": "agent/skills/learningskills/lessons/*.md",
    "default_behavior_targets": [
      "agent/skills/**",
      "Setup/**",
      "docs/**"
    ]
  }
}
