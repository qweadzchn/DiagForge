{
  "$schema": "./job.schema.json",
  "job_name": "replace-me",
  "task": {
    "input_png": "example.png",
    "final_vsdx_name": "example_final.vsdx",
    "description": "Describe what should be reproduced or emphasized."
  },
  "paths": {
    "input_dir": "../InputPNG",
    "preview_dir": "../OutputPreview",
    "final_vsdx_dir": "../OutputVSDX"
  },
  "bridge": {
    "base_url": "http://127.0.0.1:18761",
    "token_env": "VISIO_BRIDGE_TOKEN"
  },
  "execution": {
    "max_rounds": 3,
    "save_intermediate_vsdx": false,
    "export_preview_each_round": true,
    "clear_session_after_round": true,
    "record_lessons_each_round": true,
    "keep_final_vsdx": true
  }
}
