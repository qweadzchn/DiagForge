{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diagforge.local/schemas/draw-job.schema.json",
  "title": "Draw Job Config",
  "type": "object",
  "required": ["job_name", "task", "paths", "bridge", "execution"],
  "properties": {
    "run_mode": {
      "type": "string",
      "enum": ["development", "operation"],
      "description": "Optional. development allows repo-level fixes during a job; operation limits writes to job artifacts and outputs."
    },
    "job_name": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "object",
      "required": ["input_png", "final_vsdx_name"],
      "properties": {
        "input_png": {
          "type": "string",
          "description": "File name under InputReference/"
        },
        "final_vsdx_name": {
          "type": "string",
          "description": "Final VSDX file name under OutputEditable/"
        },
        "goal": {
          "type": "string",
          "description": "Preferred human success definition for this drawing task."
        },
        "diagram_hint": {
          "type": "string",
          "description": "Optional human hint such as pipeline, architecture, or mixed-layout."
        },
        "description": {
          "type": "string",
          "description": "Optional free-form notes. Prefer task.goal for the main success definition."
        }
      }
    },
    "paths": {
      "type": "object",
      "required": ["input_dir", "preview_dir", "final_vsdx_dir", "workspace_root"],
      "properties": {
        "input_dir": { "type": "string" },
        "preview_dir": { "type": "string" },
        "final_vsdx_dir": { "type": "string" },
        "workspace_root": { "type": "string" }
      }
    },
    "bridge": {
      "type": "object",
      "required": ["base_url", "token_env"],
      "properties": {
        "base_url": {
          "type": "string"
        },
        "token_env": {
          "type": "string"
        }
      }
    },
    "execution": {
      "type": "object",
      "required": [
        "max_rounds",
        "save_intermediate_vsdx",
        "export_preview_each_round",
        "clear_session_after_round",
        "record_lessons_each_round",
        "keep_final_vsdx"
      ],
      "properties": {
        "max_rounds": {
          "type": "integer",
          "minimum": 1
        },
        "save_intermediate_vsdx": {
          "type": "boolean"
        },
        "export_preview_each_round": {
          "type": "boolean"
        },
        "write_round_review_each_round": {
          "type": "boolean",
          "description": "Optional. If omitted, the workflow should still assume round review is recommended."
        },
        "clear_session_after_round": {
          "type": "boolean"
        },
        "record_lessons_each_round": {
          "type": "boolean",
          "description": "Whether each round should actively look for reusable lessons."
        },
        "stop_when_satisfied": {
          "type": "boolean",
          "description": "Optional. Stop early when preview quality is already acceptable."
        },
        "keep_final_vsdx": {
          "type": "boolean"
        }
      }
    }
  }
}
